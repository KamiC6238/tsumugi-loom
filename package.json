{
  "name": "tsumugi-loom",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:logic": "vitest run",
    "test:logic:watch": "vitest",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:install": "playwright install",
    "loom:workflow:start": "node scripts/loom/start-workflow.mjs",
    "loom:workflow:validate": "node scripts/loom/validate-workflow.mjs",
    "loom:workflow:reconcile": "node scripts/loom/reconcile-workflow.mjs"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "ajv": "^8.18.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
